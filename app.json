{
  "expo": {
    "name": "splitwise",
    "slug": "splitwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5bc5a7"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to capture receipt images for expense tracking.",
        "NSPhotoLibraryUsageDescription": "This app accesses the photo library to select receipt images for expense tracking.",
        "NSContactsUsageDescription": "Splitwise uses your contacts to find friends who are already on the app."
      },
      "bundleIdentifier": "com.prabhatsn1.splitwise"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.prabhatsn1.splitwise",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Splitwise to access your contacts to find friends already on the app."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to capture receipt images."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0442306a-5235-4a35-81ce-94872ad6abbf"
      }
    }
  }
}
